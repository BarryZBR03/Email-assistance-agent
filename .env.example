# Run from /home/baz/ai/llm_projects/email_assistance with .venv/bin/python email_summary_agent/get_email_data.py

# Mailbox settings
EMAIL_ADDRESS=user@example.com
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=user@example.com
IMAP_AUTH_CODE=replace-with-mailbox-app-password
# SMTP is used only after a user explicitly approves sending a saved draft.
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_AUTH_CODE=replace-with-mailbox-app-password

# Email fetch filters: EMAIL_STATUS must be seen, unseen, or all; RECENT_DAYS is 1-30.
EMAIL_STATUS=unseen
RECENT_DAYS=1
ALLOWED_SENDERS=

# Classification and model settings
EMAIL_CATEGORIES=important,work,personal,promotion,spam,other
OUTPUT_DIR=classified_emails
# LLM_PROVIDER accepts openai_compatible, anthropic, google, or aliases such as deepseek, qwen, kimi, claude, gemini.
LLM_PROVIDER=openai_compatible
LLM_API_KEY=replace-with-model-api-key
# LLM_BASE_URL is used for OpenAI-compatible providers such as DeepSeek, Qwen, Kimi, OpenAI, OpenRouter, vLLM, and LM Studio.
LLM_BASE_URL=https://api.deepseek.com
LLM_CLASSIFICATION_MODEL=deepseek-v4-flash
LLM_SUMMARY_MODEL=deepseek-v4-pro
LLM_DRAFT_MODEL=deepseek-v4-pro
LLM_CLASSIFICATION_MAX_CONCURRENCY=1000
LLM_DRAFT_MAX_CONCURRENCY=250
# Legacy aliases are still supported for existing DeepSeek-oriented setups.
DEEPSEEK_API_KEY=replace-with-model-api-key
BASE_URL=https://api.deepseek.com
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_SUMMARY_MODEL=deepseek-v4-pro
DEEPSEEK_DRAFT_MODEL=deepseek-v4-pro

# Draft agent settings
CLASSIFIED_EMAILS_DIR=classified_emails
DRAFT_OUTPUT_DIR=output

# Agent behavior overrides: leave blank to use defaults.
SUMMARY_SYSTEM_PROMPT=
DRAFT_SYSTEM_PROMPT=
DRAFT_PERSONALITY=

# Optional LangSmith tracing
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=

# Logging settings
LOG_LEVEL=INFO
LOG_FILE=logs/task_{task_id}/email_summary_agent.log
DRAFT_LOG_FILE=logs/task_{task_id}/email_draft_agent.log
